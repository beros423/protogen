ilot.chat.debug.showNesRequests","title":"Show NES Requests"},{"command":"github.copilot.chat.debug.hideNesRequests","title":"Hide NES Requests"},{"command":"github.copilot.chat.debug.showRawRequestBody","title":"Show Raw Request Body"},{"command":"github.copilot.chat.debug.exportLogItem","title":"Export as...","icon":"$(export)"},{"command":"github.copilot.chat.debug.exportPromptArchive","title":"Export All as Archive...","icon":"$(archive)"},{"command":"github.copilot.chat.debug.exportPromptLogsAsJson","title":"Export All as JSON...","icon":"$(export)"},{"command":"github.copilot.chat.debug.exportAllPromptLogsAsJson","title":"Export All Prompt Logs as JSON...","icon":"$(export)"},{"command":"github.copilot.chat.showAsChatSession","title":"Show as chat session","icon":"$(chat-sparkle)"},{"command":"github.copilot.debug.collectWorkspaceIndexDiagnostics","title":{"value":"작업 영역 인덱스 진단 수집","original":"Collect Workspace Index Diagnostics"},"category":"Developer"},{"command":"github.copilot.chat.mcp.setup.check","title":"MCP Check: is supported"},{"command":"github.copilot.chat.mcp.setup.validatePackage","title":"MCP Check: validate package"},{"command":"github.copilot.chat.mcp.setup.flow","title":"MCP Check: do prompts"},{"command":"github.copilot.chat.generateAltText","title":"Generate/Refine Alt Text"},{"command":"github.copilot.chat.notebook.enableFollowCellExecution","title":"Enable Follow Cell Execution from Chat","shortTitle":"Follow","icon":"$(pinned)"},{"command":"github.copilot.chat.notebook.disableFollowCellExecution","title":"Disable Follow Cell Execution from Chat","shortTitle":"Unfollow","icon":"$(pinned-dirty)"},{"command":"github.copilot.chat.manageBYOK","title":"Manage Bring Your Own Key Vendor","enablement":"false"},{"command":"github.copilot.chat.manageBYOKAPIKey","title":"Manage Bring Your Own Key API Key","enablement":"false"},{"command":"github.copilot.cloud.sessions.refresh","title":"Refresh Agent Sessions","icon":"$(refresh)"},{"command":"github.copilot.cloud.resetWorkspaceConfirmations","title":{"value":"클라우드 에이전트 작업 영역 초기화 확인","original":"Reset Cloud Agent Workspace Confirmations"}},{"command":"github.copilot.cloud.sessions.openInBrowser","title":{"value":"브라우저에서 열기","original":"Open in Browser"},"icon":"$(link-external)"},{"command":"github.copilot.cloud.sessions.proxy.closeChatSessionPullRequest","title":{"value":"끌어오기 요청 닫기","original":"Close Pull Request"}},{"command":"github.copilot.chat.openSuggestionsPanel","title":"Open Completions Panel","enablement":"github.copilot.extensionUnification.activated && !isWeb","category":"GitHub Copilot"},{"command":"github.copilot.chat.toggleStatusMenu","title":"Open Status Menu","enablement":"github.copilot.extensionUnification.activated","category":"GitHub Copilot"},{"command":"github.copilot.chat.completions.disable","title":"Disable Inline Suggestions","enablement":"github.copilot.extensionUnification.activated && github.copilot.activated && config.editor.inlineSuggest.enabled && github.copilot.completions.enabled","category":"GitHub Copilot"},{"command":"github.copilot.chat.completions.enable","title":"Enable Inline Suggestions","enablement":"github.copilot.extensionUnification.activated && github.copilot.activated && !(config.editor.inlineSuggest.enabled && github.copilot.completions.enabled)","category":"GitHub Copilot"},{"command":"github.copilot.chat.completions.toggle","title":"Toggle (Enable/Disable) Inline Suggestions","enablement":"github.copilot.extensionUnification.activated && github.copilot.activated","category":"GitHub Copilot"},{"command":"github.copilot.chat.openModelPicker","title":"Change Completions Model","category":"GitHub Copilot","enablement":"github.copilot.extensionUnification.activated && !isWeb"},{"command":"github.copilot.chat.applyCopilotCLIAgentSessionChanges","title":{"value":"작업 영역에 변경 내용 적용","original":"Apply Changes to Workspace"},"icon":"$(git-stash-pop)","category":"GitHub Copilot"},{"command":"github.copilot.chat.applyCopilotCLIAgentSessionChanges.apply","title":{"value":"적용","original":"Apply"},"icon":"$(git-stash-pop)","category":"GitHub Copilot"}],"configuration":[{"title":"GitHub Copilot Chat","id":"stable","properties":{"github.copilot.chat.codeGeneration.useInstructionFiles":{"type":"boolean","default":true,"markdownDescription":"'.github/copilot-instructions.md'의 코드 명령이 Copilot 요청에 추가되는지 여부를 제어합니다.\n\n참고: 명령은 짧고 간결하게 유지하세요. 잘못된 명령은 Copilot의 품질과 성능을 저하시킬 수 있습니다. Copilot 사용자 지정에 관해 [자세히 알아보세요](https://aka.ms/github-copilot-custom-instructions)."},"github.copilot.editor.enableCodeActions":{"type":"boolean","default":true,"description":"사용 가능한 경우 Copilot 명령이 코드 작업으로 표시되는지 제어합니다."},"github.copilot.renameSuggestions.triggerAutomatically":{"type":"boolean","default":true,"description":"Copilot이 이름 바꾸기에 대한 제안을 생성하는지 여부를 제어합니다."},"github.copilot.chat.localeOverride":{"type":"string","enum":["auto","en","fr","it","de","es","ru","zh-CN","zh-TW","ja","ko","cs","pt-br","tr","pl"],"enumDescriptions":["Use VS Code's configured display language","English","français","italiano","Deutsch","español","русский","中文(简体)","中文(繁體)","日本語","한국어","čeština","português","Türkçe","polski"],"default":"auto","markdownDescription":"Copilot이 응답해야 하는 로캘(예: 'en' 또는 'fr')을 지정합니다. 기본적으로 Copilot은 VS Code의 구성된 표시 언어 로캘을 사용하여 응답합니다."},"github.copilot.chat.terminalChatLocation":{"type":"string","default":"chatView","markdownDescription":"터미널에서 채팅 쿼리를 열어야 하는 위치를 제어합니다.","markdownEnumDescriptions":["채팅 보기를 엽니다.","빠른 채팅을 엽니다.","터미널 인라인 채팅 열기"],"enum":["chatView","quickChat","terminal"]},"github.copilot.chat.scopeSelection":{"type":"boolean","default":false,"markdownDescription":"사용자가 '/explain'을 사용하고 활성 편집기에 선택 항목이 없는 경우 사용자에게 특정 기호 범위를 선택하라는 메시지를 표시할지 여부를 지정합니다."},"github.copilot.chat.useProjectTemplates":{"type":"boolean","default":true,"markdownDescription":"'/new'를 사용할 때 관련 GitHub 프로젝트를 시작 프로젝트로 사용"},"github.copilot.nextEditSuggestions.enabled":{"type":"boolean","default":false,"tags":["nextEditSuggestions","onExp"],"markdownDescription":"NES(다음 편집 제안)를 사용할지 여부입니다.\n\nNES는 최근 변경 사항에 따라 다음 편집을 제안할 수 있습니다. 다음 편집 제안에 대해 [자세히 알아보세요](https://aka.ms/vscode-nes).","scope":"language-overridable"},"github.copilot.nextEditSuggestions.fixes":{"type":"boolean","default":true,"tags":["nextEditSuggestions","onExp"],"markdownDescription":"NES(다음 편집 제안)를 통해 진단에 대한 수정 사항을 제공할지 여부입니다.","scope":"language-overridable"},"github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges":{"type":"boolean","default":true,"tags":["nextEditSuggestions","onExp"],"markdownDescription":"다음 NES(편집 제안)에서 공백 전용 변경을 허용할지 여부를 제어합니다.","scope":"language-overridable"},"github.copilot.chat.agent.autoFix":{"type":"boolean","default":true,"description":"편집된 파일에 대한 진단을 자동으로 수정합니다.","tags":["onExp"]},"github.copilot.chat.customInstructionsInSystemMessage":{"type":"boolean","default":true,"description":"활성화하면 사용자 지정 지침과 모드 지침이 사용자 메시지 대신 시스템 메시지에 추가됩니다."},"github.copilot.chat.agent.currentEditorContext.enabled":{"type":"boolean","default":true,"description":"활성화하면 Copilot은 에이전트 모드의 컨텍스트에 현재 활성 편집기의 이름을 포함합니다."},"github.copilot.enable":{"type":"object","scope":"window","default":{"*":true,"plaintext":false,"markdown":false,"scminput":false},"additionalProperties":{"type":"boolean"},"markdownDescription":"Enable or disable auto triggering of Copilot completions for specified [languages](https://code.visualstudio.com/docs/languages/identifiers). You can still trigger suggestions manually using `Alt + \\`"},"github.copilot.selectedCompletionModel":{"type":"string","default":"","markdownDescription":"The currently selected completion model ID. To select from a list of available models, use the __\"Change Completions Model\"__ command or open the model picker (from the Copilot menu in the VS Code title bar, select __\"Configure Code Completions\"__ then __\"Change Completions Model\"__. The value must be a valid model ID. An empty value indicates that the default model will be used."}}},{"id":"preview","properties":{"github.copilot.chat.reviewAgent.enabled":{"type":"boolean","default":true,"description":"코드 검토 에이전트를 활성화합니다.","tags":["preview"]},"github.copilot.chat.reviewSelection.enabled":{"type":"boolean","default":true,"description":"현재 선택 항목에 대한 코드 검토를 활성화합니다.","tags":["preview"]},"github.copilot.chat.reviewSelection.instructions":{"type":"array","items":{"oneOf":[{"type":"object","markdownDescription":"현재 선택 항목에 대한 코드 검토를 제공하는 Copilot 요청에 추가될 파일 경로입니다. 필요에 따라 명령의 언어를 지정할 수 있습니다.","properties":{"file":{"type":"string","examples":[".copilot-review-instructions.md"]},"language":{"type":"string"}},"examples":[{"file":".copilot-review-instructions.md"}],"required":["file"]},{"type":"object","markdownDescription":"현재 선택 항목에 대한 코드 검토를 제공하는 Copilot 요청에 추가될 텍스트 명령입니다. 필요에 따라 명령의 언어를 지정할 수 있습니다.","properties":{"text":{"type":"string","examples":["Use underscore for field names."]},"language":{"type":"string"}},"required":["text"],"examples":[{"text":"Use underscore for field names."},{"text":"Resolve all TODO tasks."}]}]},"default":[],"markdownDescription":"현재 선택 항목에 대한 코드 검토를 제공하는 Copilot 요청에 추가될 명령 집합입니다.\n명령은 다음을 통해 제공될 수 있습니다. \n- 작업 영역의 파일: `{ \"file\": \"fileName\" }`\n- 자연어 텍스트: `{ \"text\": \"Use underscore for field names.\" }`\n\n참고: 지침을 짧고 명확하게 유지합니다. 잘못된 지침은 Copilot의 효율성을 저하할 수 있습니다.","examples":[[{"file":".copilot-review-instructions.md"},{"text":"Resolve all TODO tasks."}]],"tags":["preview"]},"github.copilot.chat.copilotDebugCommand.enabled":{"type":"boolean","default":true,"tags":["preview"],"description":"터미널에서 'copilot-debug' 명령이 사용하도록 설정되었는지 여부입니다."},"github.copilot.chat.codesearch.enabled":{"type":"boolean","default":false,"tags":["preview"],"markdownDescription":"'#codebase'를 사용할 때 에이전트 codesearch를 활성화할지 여부입니다."},"github.copilot.chat.byok.ollamaEndpoint":{"type":"string","default":"http://localhost:11434","tags":["preview"],"markdownDescription":"Bring Your Own Key를 통해 액세스할 때 Ollama에 사용할 엔드포인트입니다. 기본값은 localhost입니다."}}},{"id":"experimental","properties":{"github.copilot.chat.githubMcpServer.enabled":{"type":"boolean","default":false,"markdownDescription":"GitHub MCP 서버에 대한 기본 제공 지원을 활성화합니다.","tags":["experimental"]},"github.copilot.chat.githubMcpServer.toolsets":{"type":"array","default":["default"],"markdownDescription":"GitHub MCP 서버에서 사용할 도구 집합을 지정합니다. [자세히 알아보기](https://aka.ms/vscode-gh-mcp-toolsets).","items":{"type":"string"},"tags":["experimental"]},"github.copilot.chat.githubMcpServer.readonly":{"type":"boolean","default":false,"markdownDescription":"GitHub MCP 서버에 대해 읽기 전용 모드를 활성화합니다. 활성화하면 읽기 도구만 사용할 수 있습니다. [자세히 알아보기](https://aka.ms/vscode-gh-mcp-readonly).","tags":["experimental"]},"github.copilot.chat.githubMcpServer.lockdown":{"type":"boolean","default":false,"markdownDescription":"GitHub MCP 서버에 대해 잠금 모드를 활성화합니다. 활성화하면 푸시 액세스가 없는 사용자가 만든 공개 문제 세부 정보가 숨겨집니다. [자세히 알아보기](https://aka.ms/vscode-gh-mcp-lockdown).","tags":["experimental"]},"github.copilot.chat.imageUpload.enabled":{"type":"boolean","default":true,"tags":["experimental","onExp"],"markdownDescription":"채팅 요청에서 원시 base64 문자열 대신 이미지 업로드 URL을 사용할 수 있습니다."},"github.copilot.chat.edits.suggestRelatedFilesFromGitHistory":{"type":"boolean","default":true,"tags":["experimental"],"markdownDescription":"Copilot 편집 작업 집합에 대한 git 기록의 관련 파일을 제안할지 여부입니다."},"github.copilot.chat.edits.suggestRelatedFilesForTests":{"type":"boolean","default":true,"tags":["experimental"],"markdownDescription":"Copilot 편집 작업 집합에 대한 테스트 파일의 소스 파일을 제안할지 여부입니다."},"github.copilot.chat.codeGeneration.instructions":{"markdownDeprecationMessage":"대신 지침 파일을 사용하세요. 자세한 내용은 https://aka.ms/vscode-ghcp-custom-instructions를 참조하세요.","type":"array","items":{"oneOf":[{"type":"object","markdownDescription":"코드를 생성하는 Copilot 요청에 추가될 파일의 경로입니다. 필요에 따라 명령에 대한 언어를 지정할 수 있습니다.","properties":{"file":{"type":"string","examples":[".copilot-codeGeneration-instructions.md"]},"language":{"type":"string"}},"examples":[{"file":".copilot-codeGeneration-instructions.md"}],"required":["file"]},{"type":"object","markdownDescription":"코드를 생성하는 Copilot 요청에 추가될 텍스트 명령입니다. 필요에 따라 명령에 대한 언어를 지정할 수 있습니다.","properties":{"text":{"type":"string","examples":["Use underscore for field names."]},"language":{"type":"string"}},"required":["text"],"examples":[{"text":"Use underscore for field names."},{"text":"Always add a comment: 'Generated by Copilot'."}]}]},"default":[],"markdownDescription":"코드를 생성하는 Copilot 요청에 추가할 명령 집합입니다.\n명령은 다음에서 가져올 수 있습니다. \n- 작업 영역의 파일: '{ \"file\": \"fileName\" }'\n- 자연어 텍스트: `{ \"text\": \"Use underscore for field names.\" }`\n\n참고: 지침을 짧고 정확하게 유지합니다. 잘못된 지침은 Copilot의 품질과 성능을 저하시킬 수 있습니다.","examples":[[{"file":".copilot-codeGeneration-instructions.md"},{"text":"Always add a comment: 'Generated by Copilot'."}]],"tags":["experimental"]},"github.copilot.chat.testGeneration.instructions":{"markdownDeprecationMessage":"대신 지침 파일을 사용하세요. 자세한 내용은 https://aka.ms/vscode-ghcp-custom-instructions를 참조하세요.","type":"array","items":{"oneOf":[{"type":"object","markdownDescription":"테스트를 생성하는 Copilot 요청에 추가될 파일의 경로입니다. 필요에 따라 명령의 언어를 지정할 수 있습니다.","properties":{"file":{"type":"string","examples":[".copilot-test-instructions.md"]},"language":{"type":"string"}},"examples":[{"file":".copilot-test-instructions.md"}],"required":["file"]},{"type":"object","markdownDescription":"테스트를 생성하는 Copilot 요청에 추가될 텍스트 명령입니다. 필요에 따라 명령의 언어를 지정할 수 있습니다.","properties":{"text":{"type":"string","examples":["Use suite and test instead of describe and it."]},"language":{"type":"string"}},"required":["text"],"examples":[{"text":"Always try uniting related tests in a suite."}]}]},"default":[],"markdownDescription":"테스트를 생성하는 Copilot 요청에 추가할 명령 집합입니다.\n명령은 다음에서 가져올 수 있습니다. \n- 작업 영역의 파일: '{ \"file\": \"fileName\" }'\n- 자연어 텍스트: `{ \"text\": \"Use underscore for field names.\" }`\n\n참고: 지침을 짧고 정확하게 유지합니다. 잘못된 지침은 Copilot의 품질과 성능을 저하시킬 수 있습니다.","examples":[[{"file":".copilot-test-instructions.md"},{"text":"Always try uniting related tests in a suite."}]],"tags":["experimental"]},"github.copilot.chat.commitMessageGeneration.instructions":{"type":"array","items":{"oneOf":[{"type":"object","markdownDescription":"커밋 메시지를 생성하는 Copilot 요청에 추가될 지침이 있는 파일의 경로입니다.","properties":{"file":{"type":"string","examples":[".copilot-commit-message-instructions.md"]}},"examples":[{"file":".copilot-commit-message-instructions.md"}],"required":["file"]},{"type":"object","markdownDescription":"커밋 메시지를 생성하는 Copilot 요청에 추가될 텍스트 지침입니다.","properties":{"text":{"type":"string","examples":["Use conventional commit message format."]}},"required":["text"],"examples":[{"text":"Use conventional commit message format."}]}]},"default":[],"markdownDescription":"커밋 메시지를 생성하는 Copilot 요청에 추가될 일련의 지침입니다.\n명령은 다음을 통해 제공될 수 있습니다. \n- 작업 영역의 파일: `{ \"file\": \"fileName\" }`\n- 자연어 텍스트: `{ \"text\": \"Use conventional commit message format.\" }`\n\n참고: 지침을 짧고 명확하게 유지합니다. 잘못된 지침은 Copilot의 품질과 성능을 저하시킬 수 있습니다.","examples":[[{"file":".copilot-commit-message-instructions.md"},{"text":"Use conventional commit message format."}]],"tags":["experimental"]},"github.copilot.chat.pullRequestDescriptionGeneration.instructions":{"type":"array","items":{"oneOf":[{"type":"object","markdownDescription":"끌어오기 요청 제목 및 설명을 생성하는 Copilot 요청에 추가될 명령이 있는 파일의 경로입니다.","properties":{"file":{"type":"string","examples":[".copilot-pull-request-description-instructions.md"]}},"examples":[{"file":".copilot-pull-request-description-instructions.md"}],"required":["file"]},{"type":"object","markdownDescription":"끌어오기 요청 제목 및 설명을 생성하는 Copilot 요청에 추가될 텍스트 지침입니다.","properties":{"text":{"type":"string","examples":["Include every commit message in the pull request description."]}},"required":["text"],"examples":[{"text":"Include every commit message in the pull request description."}]}]},"default":[],"markdownDescription":"끌어오기 요청 제목 및 설명을 생성하는 Copilot 요청에 추가될 명령 집합입니다.\n명령은 다음을 통해 제공될 수 있습니다. \n- 작업 영역의 파일: `{ \"file\": \"fileName\" }`\n- 자연어 텍스트: `{ \"text\": \"Always include a list of key changes.\" }`\n\n참고: 명령은 짧고 간결하게 유지합니다. 잘못된 명령은 Copilot의 품질과 성능을 저하시킬 수 있습니다.","examples":[[{"file":".copilot-pull-request-description-instructions.md"},{"text":"Use conventional commit message format."}]],"tags":["experimental"]},"github.copilot.chat.generateTests.codeLens":{"type":"boolean","default":false,"description":"현재 테스트 검사 정보에서 다루지 않는 기호에 대한 '테스트 생성' 코드 렌즈를 표시합니다.","tags":["experimental"]},"github.copilot.chat.setupTests.enabled":{"type":"boolean","default":true,"markdownDescription":"'/tests' 생성 시 '/setupTests' 의도 및 프롬프트를 사용하도록 설정합니다.","tags":["experimental"]},"github.copilot.chat.languageContext.typescript.enabled":{"type":"boolean","default":false,"scope":"resource","tags":["experimental","onExP"],"markdownDescription":"인라인 제안을 사용하려면 TypeScript 언어 컨텍스트 공급자를 활성화하세요."},"github.copilot.chat.languageContext.typescript.items":{"type":"string","enum":["minimal","double","fillHalf","fill"],"default":"double","scope":"resource","tags":["experimental","onExP"],"markdownDescription":"TypeScript 언어 컨텍스트 공급자에 포함되는 항목 종류를 제어합니다."},"github.copilot.chat.languageContext.typescript.includeDocumentation":{"type":"boolean","default":false,"scope":"resource","tags":["experimental","onExP"],"markdownDescription":"생성된 코드 조각에 설명서 주석을 포함할지 여부를 제어합니다."},"github.copilot.chat.languageContext.typescript.cacheTimeout":{"type":"number","default":500,"scope":"resource","tags":["experimental","onExP"],"markdownDescription":"TypeScript 언어 컨텍스트 공급자에 대한 캐시 채우기 시간 제한(밀리초)입니다. 기본값은 500밀리초입니다."},"github.copilot.chat.languageContext.fix.typescript.enabled":{"type":"boolean","default":false,"scope":"resource","tags":["experimental","onExP"],"markdownDescription":"/fix 명령을 위해 TypeScript 언어 컨텍스트 공급자를 활성화합니다."},"github.copilot.chat.languageContext.inline.typescript.enabled":{"type":"boolean","default":false,"scope":"resource","tags":["experimental","onExP"],"markdownDescription":"인라인 채팅(생성 및 편집 모두)에 대해 TypeScript 언어 컨텍스트 공급자를 활성화합니다."},"github.copilot.chat.newWorkspaceCreation.enabled":{"type":"boolean","default":true,"tags":["experimental"],"description":"새 에이전트 작업 영역 생성을 활성화할지 여부입니다."},"github.copilot.chat.newWorkspace.useContext7":{"type":"boolean","default":false,"tags":["experimental"],"markdownDescription":"새 작업 영역 생성을 위해 [Context7](command:github.copilot.mcp.viewContext7) 도구를 사용하여 프로젝트를 스캐폴드할지 여부입니다."},"github.copilot.chat.notebook.followCellExecution.enabled":{"type":"boolean","default":false,"tags":["experimental"],"description":"Copilot에서 실행 시 현재 실행 중인 셀을 뷰포트에 표시할지 여부를 제어합니다."},"github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled":{"type":"boolean","default":false,"tags":["experimental","onExp"],"description":"Notebook 셀에서 다음 편집 제안을 생성하기 위해 향상된 접근 방식을 사용할지 여부를 제어합니다."},"github.copilot.chat.summarizeAgentConversationHistory.enabled":{"type":"boolean","default":true,"tags":["experimental"],"description":"컨텍스트 창이 채워질 경우 에이전트 대화 기록을 자동으로 요약할지 여부입니다."},"github.copilot.chat.virtualTools.threshold":{"type":"number","minimum":0,"maximum":128,"default":128,"tags":["experimental"],"markdownDescription":"이 설정은 가상 도구를 사용해야 하는 도구 개수를 정의합니다. 가상 도구는 비슷한 도구 집합을 함께 그룹화하여 모델이 필요할 때 활성화할 수 있도록 합니다. 특정 도구 그룹은 낙관적으로 사전 활성화됩니다. 이 기능은 적극적으로 개발 중이며, 임곗값에 도달하면 도구 호출 성능이 저하될 수 있습니다.\n\n가상 도구를 비활성화하려면 '0'으로 설정하세요."},"github.copilot.chat.azureAuthType":{"type":"string","enum":["entraId","apiKey"],"enumDescriptions":["Microsoft 계정 자격 증명을 사용하여 Entra ID(Azure AD) 인증을 사용하세요.","API 키 인증을 사용합니다. 토큰 기반 인증보다 보안이 낮아 권장하지 않습니다."],"default":"entraId","tags":["experimental"],"markdownDescription":"Azure OpenAI 모델의 인증 방법입니다. 엔터프라이즈 보안을 위해 Entra ID를 권장하며, Azure 자격 증명을 사용합니다."},"github.copilot.chat.azureModels":{"type":"object","default":{},"tags":["experimental"],"additionalProperties":{"type":"object","properties":{"name":{"type":"string","description":"Display name of the Azure model"},"url":{"type":"string","markdownDescription":"URL endpoint for the Azure model.\n\n**Important:** Base URLs default to Chat Completions API. Explicit API paths including `/responses` or `/chat/completions` are respected. Both behaviors are independent of the `#github.copilot.chat.useResponsesApi#` setting."},"toolCalling":{"type":"boolean","description":"Whether the model supports tool calling"},"vision":{"type":"boolean","description":"Whether the model supports vision capabilities"},"maxInputTokens":{"type":"number","description":"Maximum number of input tokens supported by the model"},"maxOutputTokens":{"type":"number","description":"Maximum number of output tokens supported by the model"},"thinking":{"type":"boolean","default":false,"description":"Whether the model supports thinking capabilities"},"zeroDataRetentionEnabled":{"type":"boolean","default":false,"markdownDescription":"Whether Zero Data Retention (ZDR) is enabled for this endpoint. When `true`, `previous_response_id` will not be sent in requests via Responses API."},"requestHeaders":{"type":"object","description":"Additional HTTP headers to include with requests to this model. These reserved headers are not allowed and ignored if present: forbidden request headers (https://developer.mozilla.org/en-US/docs/Glossary/Forbidden_request_header), forwarding headers ('forwarded', 'x-forwarded-for', 'x-forwarded-host', 'x-forwarded-proto'), and others ('api-key', 'authorization', 'content-type', 'openai-intent', 'x-github-api-version', 'x-initiator', 'x-interaction-id', 'x-interaction-type', 'x-onbehalf-extension-id', 'x-request-id', 'x-vscode-user-agent-library-version'). Pattern-based forbidden headers ('proxy-*', 'sec-*', 'x-http-method*' with forbidden methods) are also blocked.","additionalProperties":{"type":"string"}}},"required":["name","url","toolCalling","vision","maxInputTokens","maxOutputTokens"],"additionalProperties":false},"markdownDescription":"Configure custom Azure OpenAI models. Each key should be a unique model ID, and the value should be an object with model configuration including name, url, toolCalling, vision, maxInputTokens, and maxOutputTokens properties."},"github.copilot.chat.customOAIModels":{"type":"object","default":{},"tags":["experimental"],"additionalProperties":{"type":"object","properties":{"name":{"type":"string","description":"Display name of the custom OpenAI model"},"url":{"type":"string","markdownDescription":"URL endpoint for the custom OpenAI-compatible model.\n\n**Important:** Base URLs default to Chat Completions API. Explicit API paths including `/responses` or `/chat/completions` are respected. Both behaviors are independent of the `#github.copilot.chat.useResponsesApi#` setting."},"toolCalling":{"type":"boolean","description":"Whether the model supports tool calling"},"vision":{"type":"boolean","description":"Whether the model supports vision capabilities"},"maxInputTokens":{"type":"number","description":"Maximum number of input tokens supported by the model"},"maxOutputTokens":{"type":"number","description":"Maximum number of output tokens supported by the model"},"requiresAPIKey":{"type":"boolean","description":"Whether the model requires an API key for authentication","default":true},"editTools":{"type":"array","description":"List of edit tools supported by the model. If this is not configured, the editor will try multiple edit tools and pick the best one.\n\n- 'find-replace': Find and replace text in a document.\n- 'multi-find-replace': Find and replace text in a document.\n- 'apply-patch': A file-oriented diff format used by some OpenAI models\n- 'code-rewrite': A general but slower editing tool that allows the model to rewrite and code snippet and provide only the replacement to the editor.","items":{"type":"string","enum":["find-replace","multi-find-replace","apply-patch","code-rewrite"]}},"thinking":{"type":"boolean","default":false,"description":"Whether the model supports thinking capabilities"},"zeroDataRetentionEnabled":{"type":"boolean","default":false,"markdownDescription":"Whether Zero Data Retention (ZDR) is enabled for this endpoint. When `true`, `previous_response_id` will not be sent in requests via Responses API."},"requestHeaders":{"type":"object","description":"Additional HTTP headers to include with requests to this model. These reserved headers are not allowed and ignored if present: forbidden request headers (https://developer.mozilla.org/en-US/docs/Glossary/Forbidden_request_header), forwarding headers ('forwarded', 'x-forwarded-for', 'x-forwarded-host', 'x-forwarded-proto'), and others ('api-key', 'authorization', 'content-type', 'openai-intent', 'x-github-api-version', 'x-initiator', 'x-interaction-id', 'x-interaction-type', 'x-onbehalf-extension-id', 'x-request-id', 'x-vscode-user-agent-library-version'). Pattern-based forbidden headers ('proxy-*', 'sec-*', 'x-http-method*' with forbidden methods) are also blocked.","additionalProperties":{"type":"string"}}},"required":["name","url","toolCalling","vision","maxInputTokens","maxOutputTokens","requiresAPIKey"],"additionalProperties":false},"markdownDescription":"Configure custom OpenAI-compatible models. Each key should be a unique model ID, and the value should be an object with model configuration including name, url, toolCalling, vision, maxInputTokens, and maxOutputTokens properties."},"github.copilot.chat.alternateGptPrompt.enabled":{"type":"boolean","default":false,"tags":["experimental"],"description":"기본 프롬프트 대신 GPT 모델에 대한 실험적인 대체 프롬프트를 활성화합니다."},"github.copilot.chat.alternateGeminiModelFPrompt.enabled":{"type":"boolean","default":false,"tags":["experimental","onExp"],"description":"기본 프롬프트 대신 Gemini 모델 F에 대한 실험적인 대체 프롬프트를 활성화합니다."},"github.copilot.chat.useResponsesApi":{"type":"boolean","default":true,"markdownDescription":"지원되는 경우 채팅 완료 API 대신 응답 API를 사용합니다. 추론 및 추론 요약을 사용하도록 설정합니다.\n\n**참고**: 일부 사용자에 대해 아직 활성화되지 않은 실험적 기능입니다.\n\n**중요**: 사용자 지정 OpenAI 호환 및 Azure 모델에 대한 URL API 경로 확인은 이 설정과 독립적이며 '#github.copilot.chat.customOAIModels#' 또는 '#github.copilot.chat.azureModels#'의 'url' 속성에 의해 완전히 결정됩니다.","tags":["experimental","onExp"]},"github.copilot.chat.responsesApiReasoningEffort":{"type":"string","default":"default","markdownDescription":"응답 API에 사용되는 추론 작업을 설정합니다. '#github.copilot.chat.useResponsesApi#'이 필요합니다.","tags":["experimental","onExp"],"enum":["low","medium","high","default"]},"github.copilot.chat.responsesApiReasoningSummary":{"type":"string","default":"detailed","markdownDescription":"응답 API에 사용되는 추론 요약 스타일을 설정합니다. '#github.copilot.chat.useResponsesApi#'이 필요합니다.","tags":["experimental","onExp"],"enum":["off","detailed"]},"github.copilot.chat.anthropic.thinking.budgetTokens":{"type":"number","markdownDescription":"Anthropic 모델에서 확장된 사고에 할당할 최대 토큰 수입니다. 이 값을 설정하면 사고 범위가 확장됩니다. 유효 범위는 1,024~32,000개의 토큰입니다. 항상 (최대 출력 토큰 - 1)로 제한됩니다.\n\n**참고**: 일부 사용자에 대해 아직 활성화되지 않은 실험적 기능입니다.","minimum":0,"maximum":32000,"default":4000,"tags":["experimental","onExp"]},"github.copilot.chat.anthropic.tools.websearch.enabled":{"type":"boolean","default":false,"markdownDescription":"BYOK Claude 모델에서 Anthropic의 네이티브 웹 검색 도구를 활성화하세요. 활성화되면 Claude가 최신 정보를 웹에서 검색할 수 있습니다. \n\n**참고**: 이 기능은 BYOK Anthropic Claude 모델에서만 사용할 수 있는 실험적 기능입니다.","tags":["experimental","onExp"]},"github.copilot.chat.anthropic.tools.websearch.maxUses":{"type":"number","default":5,"markdownDescription":"요청당 허용되는 최대 웹 검색 횟수입니다. 유효 범위는 1에서 20까지이며, 단일 상호작용에서 과도한 API 호출을 방지합니다. 이 한도를 넘으면 응답에서 오류를 반환합니다.","minimum":1,"maximum":20,"tags":["experimental"]},"github.copilot.chat.anthropic.tools.websearch.allowedDomains":{"type":"array","default":[],"markdownDescription":"웹 검색 결과를 제한할 도메인 목록입니다(예: [\"example.com\", \"docs.example.com\"]). 도메인에 HTTP/HTTPS 스키마는 포함하지 마세요. 하위 도메인은 자동으로 포함됩니다. 차단된 도메인과 함께 사용할 수 없습니다.","items":{"type":"string"},"tags":["experimental"]},"github.copilot.chat.anthropic.tools.websearch.blockedDomains":{"type":"array","default":[],"markdownDescription":"웹 검색 결과에서 제외할 도메인 목록입니다(예: [\"untrustedsource.com\"]). 도메인에 HTTP/HTTPS 스키마는 포함하지 마세요. 하위 도메인은 자동으로 제외됩니다. 허용된 도메인과 함께 사용할 수 없습니다.","items":{"type":"string"},"tags":["experimental"]},"github.copilot.chat.anthropic.tools.websearch.userLocation":{"type":["object","null"],"default":null,"markdownDescription":"지리적 컨텍스트에 따라 웹 검색 결과를 개인 설정하기 위한 사용자 위치입니다. 모든 항목(도시, 지역, 국가, 표준 시간대)은 선택 사항입니다. 예: '{\"city\": \"San Francisco\", \"region\": \"California\", \"country\": \"US\", \"timezone\": \"America/Los_Angeles\"}'","properties":{"city":{"type":"string","description":"City name (e.g., 'San Francisco')"},"region":{"type":"string","description":"State or region (e.g., 'California')"},"country":{"type":"string","description":"ISO country code (e.g., 'US')"},"timezone":{"type":"string","description":"IANA timezone identifier (e.g., 'America/Los_Angeles')"}},"tags":["experimental"]},"github.copilot.chat.tools.memory.enabled":{"type":"boolean","default":false,"markdownDescription":"메모리 도구를 활성화하여 모델이 대화 중 정보를 저장하고 불러올 수 있도록 허용합니다. \n\n**참고**: 이 기능은 실험적 기능입니다.","tags":["experimental","onExp"]},"github.copilot.chat.completionsFetcher":{"type":["string","null"],"markdownDescription":"인라인 완성에 사용되는 페처를 설정합니다.","tags":["experimental","onExp"],"enum":["electron-fetch","node-fetch"]},"github.copilot.chat.nesFetcher":{"type":["string","null"],"markdownDescription":"다음 편집 제안에 사용되는 페처를 설정합니다.","tags":["experimental","onExp"],"enum":["electron-fetch","node-fetch"]},"github.copilot.chat.customAgents.showOrganizationAndEnterpriseAgents":{"type":"boolean","default":false,"description":"GitHub Enterprise와 조직의 사용자 지정 에이전트를 사용하도록 설정합니다. 사용하도록 설정하지 않으면 Copilot에서 조직이나 엔터프라이즈의 사용자 지정 에이전트를 사용할 수 없습니다.","tags":["experimental"]}}},{"id":"advanced","properties":{"github.copilot.chat.debug.overrideChatEngine":{"type":["string","null"],"markdownDescription":"채팅 모델을 재정의합니다. 이렇게 하면 다른 모델로 테스트할 수 있습니다.\n\n**참고**: 이 설정은 고급 디버깅 설정이며, 최종 사용자와 다른 환경을 제공할 수 있으므로 자체 호스팅하는 동안 사용하면 안 됩니다.","tags":["advanced","experimental"]},"github.copilot.chat.edits.gemini3MultiReplaceString":{"type":"boolean","default":false,"markdownDescription":"Enable the modern `multi_replace_string_in_file` edit tool when generating edits with Gemini 3 models.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.projectLabels.expanded":{"type":"boolean","default":false,"markdownDescription":"프롬프트에서 프로젝트 레이블에 확장된 형식을 사용합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.projectLabels.chat":{"type":"boolean","default":false,"markdownDescription":"채팅 요청에 프로젝트 레이블을 추가합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.projectLabels.inline":{"type":"boolean","default":false,"markdownDescription":"인라인 편집 요청에 프로젝트 레이블을 추가합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.workspace.maxLocalIndexSize":{"type":"number","default":100000,"markdownDescription":"로컬 작업 영역 인덱스의 최대 크기입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.workspace.enableFullWorkspace":{"type":"boolean","default":true,"markdownDescription":"전체 작업 영역 컨텍스트 분석을 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.workspace.enableCodeSearch":{"type":"boolean","default":true,"markdownDescription":"작업 영역 컨텍스트에서 코드 검색을 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.workspace.enableEmbeddingsSearch":{"type":"boolean","default":true,"markdownDescription":"작업 영역 컨텍스트에서 포함 기반 검색을 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.workspace.preferredEmbeddingsModel":{"type":"string","default":"","markdownDescription":"의미 체계 검색을 위한 기본 포함 모델입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.workspace.prototypeAdoCodeSearchEndpointOverride":{"type":"string","default":"","markdownDescription":"Azure DevOps 코드 검색 프로토타입에 대한 엔드포인트를 재정의합니다.","tags":["advanced","experimental"]},"github.copilot.chat.feedback.onChange":{"type":"boolean","default":false,"markdownDescription":"구성 변경에 대한 피드백 수집을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.review.intent":{"type":"boolean","default":false,"markdownDescription":"코드 검토를 위해 의도 검색을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.notebook.summaryExperimentEnabled":{"type":"boolean","default":false,"markdownDescription":"전자 필기장 요약 실험을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.notebook.variableFilteringEnabled":{"type":"boolean","default":false,"markdownDescription":"셀 문서 기호별로 변수 필터링을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.notebook.alternativeFormat":{"type":"string","default":"xml","enum":["xml","markdown"],"markdownDescription":"전자 필기장의 대체 문서 형식입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.notebook.alternativeNESFormat.enabled":{"type":"boolean","default":false,"markdownDescription":"전자 필기장의 다음 편집 제안에 대한 대체 형식을 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.debugTerminalCommandPatterns":{"type":"array","default":[],"items":{"type":"string"},"markdownDescription":"\"디버그 명령\" 빠른 수정 작업이 디버그 터미널에 표시되어야 하는 명령 목록입니다.","tags":["advanced","experimental"]},"github.copilot.chat.localWorkspaceRecording.enabled":{"type":"boolean","default":false,"markdownDescription":"분석을 위해 로컬 작업 영역 기록을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.editRecording.enabled":{"type":"boolean","default":false,"markdownDescription":"분석을 위해 편집 기록을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.inlineChat.selectionRatioThreshold":{"type":"number","default":0,"markdownDescription":"인라인 채팅에 대한 편집 전략을 전환할 임계값입니다. 코드 선택 영역이 구문 분석 트리 노드와 일치하면, 해당 부분만 언어 모델에 전달됩니다. 이로 인해 응답 속도는 빨라지지만 결과 품질은 다소 낮아질 수 있습니다. 문서에 구문 분석 트리가 있어야 하며, 'inlineChat.enableV2' 설정이 필요합니다. 값은 0에서 1 사이여야 하며, 0은 기능이 꺼진 상태, 1은 선택 영역이 구문 분석 트리 노드와 완벽히 일치함을 뜻합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.debug.requestLogger.maxEntries":{"type":"number","default":100,"markdownDescription":"디버깅을 위해 요청 로거에 유지할 최대 항목 수입니다.","tags":["advanced","experimental"]},"github.copilot.chat.inlineEdits.diagnosticsContextProvider.enabled":{"type":"boolean","default":false,"markdownDescription":"다음 편집 제안을 위해 진단 컨텍스트 공급자를 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.codesearch.agent.enabled":{"type":"boolean","default":true,"markdownDescription":"에이전트 모드에서 코드 검색 기능을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.agent.temperature":{"type":["number","null"],"markdownDescription":"에이전트 모드 요청에 대한 온도 설정입니다.","tags":["advanced","experimental"]},"github.copilot.chat.instantApply.shortContextModelName":{"type":"string","default":"gpt-4o-instant-apply-full-ft-v66-short","markdownDescription":"짧은 컨텍스트 인스턴트 적용을 위한 모델 이름입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.instantApply.shortContextLimit":{"type":"number","default":8000,"markdownDescription":"짧은 컨텍스트 즉시 적용을 위한 토큰 제한입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.enableUserPreferences":{"type":"boolean","default":false,"markdownDescription":"에이전트 모드에서 사용자 기본 설정 저장을 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.summarizeAgentConversationHistoryThreshold":{"type":["number","null"],"markdownDescription":"에이전트 대화 기록을 요약하는 임계값입니다.","tags":["advanced","experimental"]},"github.copilot.chat.agentHistorySummarizationMode":{"type":["string","null"],"markdownDescription":"에이전트 기록 요약 모드입니다.","tags":["advanced","experimental"]},"github.copilot.chat.agentHistorySummarizationWithPromptCache":{"type":"boolean","default":false,"markdownDescription":"에이전트 기록 요약에 프롬프트 캐싱을 사용합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.agentHistorySummarizationForceGpt41":{"type":"boolean","default":false,"markdownDescription":"에이전트 기록 요약을 위해 GPT-4.1을 강제로 적용합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.useResponsesApiTruncation":{"type":"boolean","default":false,"markdownDescription":"잘림에 Responses API를 사용합니다.","tags":["advanced","experimental"]},"github.copilot.chat.omitBaseAgentInstructions":{"type":"boolean","default":false,"markdownDescription":"프롬프트에서 기본 에이전트 지침을 생략합니다.","tags":["advanced","experimental"]},"github.copilot.chat.promptFileContextProvider.enabled":{"type":"boolean","default":true,"markdownDescription":"프롬프트 파일 컨텍스트 공급자를 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.tools.defaultToolsGrouped":{"type":"boolean","default":false,"markdownDescription":"프롬프트에서 기본 도구를 그룹화합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.claudeCode.enabled":{"type":["boolean","string"],"default":false,"markdownDescription":"Claude 코드 에이전트를 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.claudeCode.debug":{"type":"boolean","default":false,"markdownDescription":"Claude 코드 에이전트의 디버그 모드를 사용하도록 설정합니다.","tags":["advanced","experimental"]},"github.copilot.chat.gpt5AlternativePatch":{"type":"boolean","default":false,"markdownDescription":"GPT-5 대체 패치 형식을 사용하도록 설정합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.inlineEdits.triggerOnEditorChangeAfterSeconds":{"type":["number","null"],"markdownDescription":"편집기가 이 시간(초) 동안 유휴 상태인 후에 인라인 편집을 트리거합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.inlineEdits.nextCursorPrediction.displayLine":{"type":"boolean","default":true,"markdownDescription":"다음 편집 제안을 위해 예측된 커서 줄을 표시합니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.inlineEdits.nextCursorPrediction.currentFileMaxTokens":{"type":"number","default":2000,"markdownDescription":"다음 커서 예측에서 현재 파일에 대한 최대 토큰입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.inlineEdits.renameSymbolSuggestions":{"type":"boolean","default":false,"markdownDescription":"인라인 편집에서 기호 제안 이름을 바꿀 수 있습니다.","tags":["advanced","experimental","onExp"]},"github.copilot.nextEditSuggestions.preferredModel":{"type":"string","default":"none","markdownDescription":"다음 편집 제안에 권장되는 모델입니다.","tags":["advanced","experimental","onExp"]},"github.copilot.chat.suggestRelatedFilesFromGitHistory.useEmbeddings":{"type":"boolean","default":false,"markdownDescription":"포함을 사용하여 git 기록에서 관련 파일을 제안