{
    "project_settings": {
        "default_plate_types": [96, 384],
        "supported_file_formats": [".csv", ".xlsx", ".xls"],
        "max_experiments_per_batch": 100,
        "default_optimization_iterations": 10
    },
    "model_settings": {
        "cross_validation_folds": 5,
        "random_state": 42,
        "test_size": 0.2
    },
    "bayesian_optimization": {
        "init_points": 5,
        "acquisition_function": "ucb",
        "kappa": 2.576
    },
    "ui_settings": {
        "page_config": {
            "layout": "wide",
            "initial_sidebar_state": "expanded"
        },
        "color_scheme": {
            "primary": "#FF6B6B",
            "secondary": "#4ECDC4",
            "background": "#F7F9FC"
        }
    },
    "experiment_templates": {
        "protein_expression": {
            "variables": [
                {"name": "Promoter", "type": "categorical", "default_values": ["P1", "P2", "P3", "P4"]},
                {"name": "CDS", "type": "categorical", "default_values": ["Gene_A", "Gene_B", "Gene_C", "Gene_D"]},
                {"name": "Temperature", "type": "numerical", "min": 25, "max": 40},
                {"name": "pH", "type": "numerical", "min": 6.0, "max": 8.0},
                {"name": "Inducer_Conc", "type": "numerical", "min": 0.1, "max": 1.0}
            ],
            "target": "Expression_Level"
        },
        "metabolic_engineering": {
            "variables": [
                {"name": "Strain", "type": "categorical", "default_values": ["WT", "Mutant1", "Mutant2"]},
                {"name": "Medium", "type": "categorical", "default_values": ["YPD", "SD", "SC"]},
                {"name": "Temperature", "type": "numerical", "min": 25, "max": 37},
                {"name": "Glucose_Conc", "type": "numerical", "min": 0.5, "max": 4.0}
            ],
            "target": "Product_Yield"
        }
    }
}